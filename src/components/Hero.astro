---
---

<section class="relative min-h-[90vh] flex items-center bg-ink-strong overflow-hidden">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/30 z-10"></div>
    <!-- Placeholder: replace with real hero photo -->
    <div class="absolute inset-0 bg-gradient-to-br from-espresso via-accent-dark/30 to-ink-strong"></div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40">
    <div class="max-w-2xl">
      <!-- Eyebrow -->
      <p class="text-accent text-xs sm:text-sm font-semibold tracking-widest uppercase mb-4">
        Hardwood Floor Refinishing & Installation in Rhode Island
      </p>

      <!-- Main heading -->
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl text-on-dark leading-[1.1] tracking-tight mb-6">
        Rhode Island<br />Hardwood Specialists
      </h1>

      <!-- Subtext -->
      <p class="text-on-dark/80 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl">
        Dustless sanding, custom stain matching, and premium finishes trusted by homeowners across Rhode Island and Southeastern Massachusetts.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-10">
        <a href="#contact" class="inline-flex items-center justify-center bg-accent text-white font-extrabold text-base px-8 py-4 rounded-default hover:bg-accent-dark transition-colors border-2 border-accent hover:border-accent-dark">
          Get a Free Estimate
        </a>
        <a href="#gallery" class="inline-flex items-center justify-center bg-transparent text-white font-bold text-base px-8 py-4 rounded-default border-2 border-white/50 hover:border-white hover:bg-white/10 transition-all">
          View Before & After
        </a>
      </div>

      <!-- Trust line -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-on-dark/90 text-sm font-medium">
        <span class="flex items-center gap-1.5">
          <span class="text-accent">&#9733;</span> 5-Star Rated
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Licensed & Insured
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Serving RI Since 2015
        </span>
      </div>
    </div>
  </div>
</section>
