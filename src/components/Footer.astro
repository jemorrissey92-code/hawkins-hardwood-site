---
const currentYear = new Date().getFullYear();
const services = [
  'New Installation',
  'Dustless Sanding',
  'Floor Refinishing',
  'Custom Staining',
  'Floor Repairs',
  'Screen & Recoat',
];
const areas = [
  'Providence', 'Warwick', 'Cranston', 'Pawtucket',
  'East Greenwich', 'Smithfield', 'North Kingstown',
];
---

<footer class="bg-ink-strong text-on-dark/70 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-accent rounded-default flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
            </svg>
          </div>
          <div>
            <span class="font-display text-lg text-on-dark">Hawkins</span>
            <span class="block text-xs text-on-dark/50 tracking-wide uppercase">Hardwood Flooring</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-4">
          Family-owned hardwood flooring specialists serving Rhode Island and Southeastern Massachusetts since 2015.
        </p>
        <div class="flex gap-3">
          <a href="http://facebook.com/HawkinsFlooring" target="_blank" rel="noopener" class="w-8 h-8 bg-white/10 rounded flex items-center justify-center hover:bg-accent transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/hawkinshardwoodfloors/" target="_blank" rel="noopener" class="w-8 h-8 bg-white/10 rounded flex items-center justify-center hover:bg-accent transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.yelp.com/biz/hawkins-hardwood-flooring-smithfield" target="_blank" rel="noopener" class="w-8 h-8 bg-white/10 rounded flex items-center justify-center hover:bg-accent transition-colors" aria-label="Yelp">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 011.596-.206 7.26 7.26 0 011.91 3.063c.238.747-.097 1.313-.24 1.648z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display text-sm text-on-dark uppercase tracking-wide mb-4">Services</h4>
        <ul class="space-y-2.5">
          {services.map(s => (
            <li><a href="#services" class="text-sm hover:text-accent transition-colors">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h4 class="font-display text-sm text-on-dark uppercase tracking-wide mb-4">Service Areas</h4>
        <ul class="space-y-2.5">
          {areas.map(a => (
            <li><a href="#areas" class="text-sm hover:text-accent transition-colors">{a}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-sm text-on-dark uppercase tracking-wide mb-4">Contact</h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="tel:+14014865587" class="hover:text-accent transition-colors">(401) 486-5587</a>
          </li>
          <li>
            <a href="mailto:John@hawkinshardwoodflooring.com" class="hover:text-accent transition-colors break-all">John@hawkinshardwoodflooring.com</a>
          </li>
          <li>5 Stephen Street<br />Smithfield, RI 02828</li>
          <li>Mon-Sat: 8am-5pm</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-on-dark/40">
        &copy; {currentYear} Hawkins Hardwood Flooring. All rights reserved.
      </p>
      <p class="text-xs text-on-dark/40">
        Built by <a href="https://eightysixstrategies.com" target="_blank" rel="noopener" class="text-accent/60 hover:text-accent">Eighty Six Strategies</a>
      </p>
    </div>
  </div>
</footer>
