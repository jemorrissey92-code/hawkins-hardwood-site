---
---

<section id="contact" class="py-20 lg:py-28 bg-espresso text-on-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left: Info -->
      <div>
        <p class="text-accent text-xs font-semibold tracking-widest uppercase mb-3">Contact Us</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-[2.6rem] text-on-dark leading-tight mb-6">
          Get Your Free Estimate
        </h2>
        <p class="text-on-dark/70 text-lg leading-relaxed mb-10">
          Ready to transform your floors? Contact us for a no-pressure estimate. We'll assess your space, discuss options, and give you honest guidance on what's worth doing.
        </p>

        <!-- Contact details -->
        <div class="space-y-6">
          <a href="tel:+14014865587" class="flex items-center gap-4 group">
            <div class="w-12 h-12 bg-accent/20 rounded-default flex items-center justify-center group-hover:bg-accent transition-colors">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <span class="block text-sm text-on-dark/50 font-medium">Phone</span>
              <span class="text-lg font-semibold text-on-dark group-hover:text-accent transition-colors">(401) 486-5587</span>
            </div>
          </a>

          <a href="mailto:John@hawkinshardwoodflooring.com" class="flex items-center gap-4 group">
            <div class="w-12 h-12 bg-accent/20 rounded-default flex items-center justify-center group-hover:bg-accent transition-colors">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <span class="block text-sm text-on-dark/50 font-medium">Email</span>
              <span class="text-lg font-semibold text-on-dark group-hover:text-accent transition-colors">John@hawkinshardwoodflooring.com</span>
            </div>
          </a>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-accent/20 rounded-default flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <span class="block text-sm text-on-dark/50 font-medium">Location</span>
              <span class="text-lg font-semibold text-on-dark">5 Stephen Street, Smithfield, RI 02828</span>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-accent/20 rounded-default flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <span class="block text-sm text-on-dark/50 font-medium">Hours</span>
              <span class="text-lg font-semibold text-on-dark">Mon-Sat: 8am-5pm</span>
              <span class="block text-sm text-on-dark/50">Sunday: Closed</span>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex gap-4 mt-10">
          <a href="http://facebook.com/HawkinsFlooring" target="_blank" rel="noopener" class="w-10 h-10 bg-accent/20 rounded-default flex items-center justify-center hover:bg-accent transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5 text-on-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/hawkinshardwoodfloors/" target="_blank" rel="noopener" class="w-10 h-10 bg-accent/20 rounded-default flex items-center justify-center hover:bg-accent transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5 text-on-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.yelp.com/biz/hawkins-hardwood-flooring-smithfield" target="_blank" rel="noopener" class="w-10 h-10 bg-accent/20 rounded-default flex items-center justify-center hover:bg-accent transition-colors" aria-label="Yelp">
            <svg class="w-5 h-5 text-on-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 011.596-.206 7.26 7.26 0 011.91 3.063c.238.747-.097 1.313-.24 1.648zM16.59 17.8l-3.517-3.57c-.68-.69.068-1.821.97-1.47l5.114 1.98a1.072 1.072 0 01.418 1.573 7.26 7.26 0 01-2.623 1.82c-.66.26-1.27.22-1.362-.333zM12.35 19.96l-.588-5.197c-.08-1.028 1.24-1.524 1.726-.65l2.842 4.402c.363.563.115 1.208-.26 1.573a7.26 7.26 0 01-3.212 1.148c-.745.097-1.282-.193-1.508-1.276zM4.846 3.96l4.24 7.05c.467.82-.352 1.741-1.242 1.393L2.592 10.27a1.072 1.072 0 01-.598-1.467A12.96 12.96 0 014.846 3.96z"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="bg-white/10 backdrop-blur-sm rounded-lg p-8 border border-white/10">
        <h3 class="font-display text-xl text-on-dark mb-6">Request a Free Estimate</h3>
        <form name="contact" method="POST" data-netlify="true" class="space-y-5">
          <input type="hidden" name="form-name" value="contact" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm text-on-dark/70 mb-1.5">Full Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-default bg-white/10 border border-white/20 text-on-dark placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent" placeholder="John Smith" />
            </div>
            <div>
              <label for="phone" class="block text-sm text-on-dark/70 mb-1.5">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-default bg-white/10 border border-white/20 text-on-dark placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent" placeholder="(401) 555-1234" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm text-on-dark/70 mb-1.5">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-default bg-white/10 border border-white/20 text-on-dark placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent" placeholder="john@example.com" />
          </div>
          <div>
            <label for="service" class="block text-sm text-on-dark/70 mb-1.5">Service Needed</label>
            <select id="service" name="service" class="w-full px-4 py-3 rounded-default bg-white/10 border border-white/20 text-on-dark focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent">
              <option value="" class="text-ink">Select a service...</option>
              <option value="installation" class="text-ink">New Hardwood Installation</option>
              <option value="refinishing" class="text-ink">Dustless Sanding & Refinishing</option>
              <option value="staining" class="text-ink">Custom Staining & Color Matching</option>
              <option value="repair" class="text-ink">Floor Repairs</option>
              <option value="maintenance" class="text-ink">Screen & Recoat</option>
              <option value="other" class="text-ink">Other / Not Sure</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm text-on-dark/70 mb-1.5">Tell Us About Your Project</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-default bg-white/10 border border-white/20 text-on-dark placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent resize-none" placeholder="Approximate square footage, type of floors, desired timeline..."></textarea>
          </div>
          <button type="submit" class="w-full bg-accent text-white font-extrabold text-base px-8 py-4 rounded-default hover:bg-accent-dark transition-colors">
            Get My Free Estimate
          </button>
          <p class="text-on-dark/40 text-xs text-center">We respond within 24 hours. No spam, ever.</p>
        </form>
      </div>
    </div>
  </div>
</section>
